# OVH API credentials
OVH_ENDPOINT=ovh-ca
OVH_APPLICATION_KEY=your_application_key
OVH_APPLICATION_SECRET=your_application_secret
OVH_CONSUMER_KEY=your_consumer_key

# Flask session secret — use a long random string
FLASK_SECRET_KEY=change_me_to_a_long_random_secret

# Admin user (full access: view, snapshot, reboot)
ADMIN_USERNAME=admin
# Generate with: python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# Viewer user (read-only: view status only)
VIEWER_USERNAME=viewer
VIEWER_PASSWORD_HASH=
